{
  "name": "agent.pw",
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "type": "module",
  "exports": {
    ".": "./packages/server/src/index.ts",
    "./paths": "./packages/server/src/paths.ts",
    "./access": "./packages/server/src/access.ts",
    "./sql": "./packages/server/src/sql/index.ts",
    "./better-auth": "./packages/server/src/better-auth/index.ts"
  },
  "scripts": {
    "build": "pnpm typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "knip": "knip",
    "lint": "biome lint .",
    "fmt": "biome lint --write --unsafe .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "tsx ./node_modules/drizzle-kit/bin.cjs generate"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@smithery/biscuit": "^1.0.1",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.44.1",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "biome-plugin-no-type-assertion": "^1.0.2",
    "drizzle-kit": "^0.30.5",
    "knip": "^5.86.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
