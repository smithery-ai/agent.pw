{
  "name": "warden",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "type": "module",
  "bin": {
    "agent.pw": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "CLOUDFLARE_INCLUDE_PROCESS_ENV=true infisical run --path=/apps/warden --env=dev --silent -- wrangler dev",
    "dev:env": "wrangler dev",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "infisical run --path=/apps/warden --env=dev --silent -- drizzle-kit migrate",
    "db:studio": "infisical run --path=/apps/warden --env=dev --silent -- drizzle-kit studio",
    "db:push": "infisical run --path=/apps/warden --env=dev --silent -- drizzle-kit push",
    "setup": "infisical run --path=/apps/warden --env=dev --silent -- tsx scripts/setup.ts",
    "managed-oauth": "infisical run --path=/apps/warden --env=dev --silent -- tsx scripts/managed-oauth.ts",
    "secrets:login": "infisical login",
    "secrets:export": "infisical export --path=/apps/warden --env=dev --format=dotenv > .env",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "compile": "bun build --compile src/cli/index.ts --outfile dist/agent.pw",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agent.pw/sdk": "https://pkg.stainless.com/s/agent.pw-typescript/8d621242b12afb4496150481c18e6a80ed58eb91/dist.tar.gz",
    "@electric-sql/pglite": "^0.2.17",
    "@hono/standard-validator": "^0.2.2",
    "@logtail/edge": "^0.5.7",
    "@smithery/biscuit": "^1.0.0",
    "@workos-inc/node": "^8.8.0",
    "drizzle-orm": "^0.44.1",
    "hono": "^4.12.0",
    "hono-openapi": "^1.3.0",
    "postgres": "^3.4.5",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.69.0"
  }
}
