{
  "name": "@agent.pw/server",
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "type": "module",
  "bin": {
    "agent.pw": "./packages/cli/dist/index.js"
  },
  "exports": {
    ".": "./packages/server/src/core/app.ts",
    "./types": "./packages/server/src/core/types.ts",
    "./db": "./packages/server/src/db/index.ts",
    "./db/queries": "./packages/server/src/db/queries.ts",
    "./db/schema": "./packages/server/src/db/schema/index.ts",
    "./db/migrate-local": "./packages/server/src/db/migrate-local.ts",
    "./logger": "./packages/server/src/lib/logger.ts",
    "./crypto": "./packages/server/src/lib/credentials-crypto.ts",
    "./utils": "./packages/server/src/lib/utils.ts",
    "./scopes": "./packages/server/src/scopes.ts",
    "./paths": "./packages/server/src/paths.ts",
    "./rights": "./packages/server/src/rights.ts",
    "./dns": "./packages/server/src/lib/dns.ts",
    "./biscuit": "./packages/server/src/biscuit.ts",
    "./proxy": "./packages/server/src/proxy.ts",
    "./auth-schemes": "./packages/server/src/auth-schemes.ts",
    "./pagination": "./packages/server/src/lib/pagination.ts"
  },
  "scripts": {
    "build": "pnpm typecheck && pnpm --filter agent.pw build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "knip": "knip",
    "lint": "biome lint .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "openapi:generate": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@hono/node-server": "^1.19.11",
    "@hono/standard-validator": "^0.2.2",
    "@smithery/biscuit": "^1.0.1",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.44.1",
    "hono": "^4.12.0",
    "hono-openapi": "^1.3.0",
    "postgres": "^3.4.5",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.30.5",
    "knip": "^5.86.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
