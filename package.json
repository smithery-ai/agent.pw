    "drizzle-orm": "^0.44.1",
    "hono": "^4.12.0",
    "hono-openapi": "^1.3.0",
    "postgres": "^3.4.5",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
