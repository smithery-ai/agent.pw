{
  "name": "@agent.pw/server",
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.0",
  "type": "module",
  "exports": {
    ".": "./src/core/app.ts",
    "./types": "./src/core/types.ts",
    "./db": "./src/db/index.ts",
    "./db/queries": "./src/db/queries.ts",
    "./db/schema": "./src/db/schema/index.ts",
    "./db/migrate-local": "./src/db/migrate-local.ts",
    "./logger": "./src/lib/logger.ts",
    "./crypto": "./src/lib/credentials-crypto.ts",
    "./utils": "./src/lib/utils.ts",
    "./dns": "./src/lib/dns.ts",
    "./biscuit": "./src/biscuit.ts",
    "./proxy": "./src/proxy.ts",
    "./auth-schemes": "./src/auth-schemes.ts",
    "./service-preview": "./src/service-preview.ts"
  },
  "scripts": {
    "build": "drizzle-kit generate && tsc -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "db:generate": "drizzle-kit generate",
    "openapi:generate": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@hono/standard-validator": "^0.2.2",
