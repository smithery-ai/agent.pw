{
  "name": "agent.pw",
  "version": "0.8.0",
  "description": "Credential vault and auth framework for agents",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smithery-ai/agent.pw.git"
  },
  "type": "module",
  "exports": {
    ".": "./packages/server/src/index.ts",
    "./paths": "./packages/server/src/paths.ts",
    "./oauth": "./packages/server/src/oauth.ts",
    "./rules": "./packages/server/src/rules.ts",
    "./sql": "./packages/server/src/sql/index.ts",
    "./types": "./packages/server/src/types.ts",
    "./errors": "./packages/server/src/errors.ts"
  },
  "scripts": {
    "build": "pnpm typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "knip": "knip",
    "lint": "node ./node_modules/oxlint/dist/cli.js .",
    "lint:fix": "node ./node_modules/oxlint/dist/cli.js --fix .",
    "fmt": "node ./node_modules/oxfmt/dist/cli.js",
    "fmt:check": "node ./node_modules/oxfmt/dist/cli.js --check",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "drizzle-orm": "^0.44.1",
    "oauth4webapi": "^3.8.5",
    "okay-error": "^1.0.4",
    "postgres": "^3.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "knip": "^5.86.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.8.0"
}
