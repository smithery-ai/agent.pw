{
  "name": "agent.pw",
  "version": "0.1.0",
  "description": "CLI for agent.pw — the password manager for AI agents",
  "type": "module",
  "license": "FSL-1.1-MIT",
  "bin": {
    "agent.pw": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/smithery-ai/agent.pw",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "compile": "node scripts/compile.mjs",
    "compile:bin": "node scripts/compile.mjs --binary",
    "generate:server-binary-manifest": "node scripts/generate-server-binary-manifest.mjs",
    "prepublishOnly": "bun run compile"
  },
  "dependencies": {
    "@smithery/biscuit": "^1.0.1"
  },
  "devDependencies": {
    "@agent.pw/sdk": "https://pkg.stainless.com/s/agent.pw-typescript/81f700c2e1cb502311f343261ee671a08d19677d/dist.tar.gz",
    "@types/node": "^25.3.3",
    "commander": "^14.0.3",
    "typescript": "^5.9.3"
  }
}
