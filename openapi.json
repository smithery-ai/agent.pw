{
  "openapi": "3.1.0",
  "info": {
    "title": "agent.pw API",
    "description": "API for managing credential profiles, credentials, tokens, and proxying authenticated requests.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.agent.pw"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Biscuit bearer token"
      }
    },
    "schemas": {
      "ApiKeyScheme": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "const": "apiKey"
          },
          "in": {
            "default": "header",
            "type": "string",
            "enum": [
              "header",
              "query",
              "cookie"
            ]
          },
          "name": {
            "default": "Authorization",
            "type": "string"
          }
        },
        "required": [
          "type",
          "in",
          "name"
        ],
        "additionalProperties": false,
        "id": "ApiKeyScheme"
      },
      "HttpScheme": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "const": "http"
          },
          "scheme": {
            "type": "string",
            "enum": [
              "bearer",
              "basic"
            ]
          }
        },
        "required": [
          "type",
          "scheme"
        ],
        "additionalProperties": false,
        "id": "HttpScheme"
      },
      "OAuth2Scheme": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "const": "oauth2"
          },
          "authorizeUrl": {
            "type": "string"
          },
          "tokenUrl": {
            "type": "string"
          },
          "scopes": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "authorizeUrl",
          "tokenUrl"
        ],
        "additionalProperties": false,
        "id": "OAuth2Scheme"
      },
      "AuthScheme": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/ApiKeyScheme"
          },
          {
            "$ref": "#/components/schemas/HttpScheme"
          },
          {
            "$ref": "#/components/schemas/OAuth2Scheme"
          }
        ]
      },
      "CredProfile": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "description": "Unique profile identifier",
            "example": "linear"
          },
          "host": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hostnames this profile applies to",
            "example": [
              "api.linear.app"
            ]
          },
          "path": {
            "type": "string",
            "description": "Path in the hierarchy",
            "example": "/"
          },
          "displayName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Human-readable display name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Profile description"
          },
          "authSchemes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthScheme"
            },
            "description": "Supported authentication schemes from the profile auth config",
            "example": [
              {
                "type": "oauth2",
                "authorizeUrl": "https://linear.app/oauth/authorize",
                "tokenUrl": "https://api.linear.app/oauth/token"
              }
            ]
          },
          "managedOauthConfigured": {
            "type": "boolean",
            "description": "Whether this profile has enough managed OAuth config to start a managed connection",
            "example": true
          }
        },
        "required": [
          "slug",
          "host",
          "path",
          "displayName",
          "description",
          "authSchemes",
          "managedOauthConfigured"
        ],
        "additionalProperties": false
      },
      "CredProfileDetail": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "description": "Unique profile identifier",
            "example": "linear"
          },
          "host": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hostnames this profile applies to",
            "example": [
              "api.linear.app"
            ]
          },
          "path": {
            "type": "string",
            "description": "Path in the hierarchy",
            "example": "/"
          },
          "displayName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Human-readable display name"
          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Profile description"
          },
          "authSchemes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthScheme"
            },
            "description": "Supported authentication schemes from the profile auth config",
            "example": [
              {
                "type": "oauth2",
                "authorizeUrl": "https://linear.app/oauth/authorize",
                "tokenUrl": "https://api.linear.app/oauth/token"
              }
            ]
          },
          "managedOauthConfigured": {
            "type": "boolean",
            "description": "Whether this profile has enough managed OAuth config to start a managed connection",
            "example": true
          },
          "auth": {
            "anyOf": [
              {},
              {
                "type": "null"
              }
            ],
            "description": "Auth configuration (OAuth or headers)"
          }
        },
        "required": [
          "slug",
          "host",
          "path",
          "displayName",
          "description",
          "authSchemes",
          "managedOauthConfigured",
          "auth"
        ],
        "additionalProperties": false
      },
      "CredProfileListPage": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CredProfile"
            }
          },
          "hasMore": {
            "type": "boolean",
            "description": "Whether more items remain after this page"
          },
          "nextCursor": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Cursor to request the next page"
          }
        },
        "required": [
          "data",
          "hasMore",
          "nextCursor"
        ],
        "additionalProperties": false
      },
      "CreateCredProfileRequest": {
        "type": "object",
        "properties": {
          "host": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Hostnames this profile applies to"
          },
          "path": {
            "description": "Path for this profile (defaults to token path)",
            "example": "/",
            "type": "string"
          },
          "auth": {
            "description": "Auth configuration",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "managedOauth": {
            "description": "Managed OAuth config",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          },
          "displayName": {
            "description": "Human-readable display name",
            "type": "string"
          },
          "description": {
            "description": "Profile description",
            "type": "string"
          }
        },
        "required": [
          "host"
        ],
        "additionalProperties": false
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Profile not found"
          }
        },
        "required": [
          "error"
        ],
        "additionalProperties": false
      },
      "Ok": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          }
        },
        "required": [
          "ok"
        ],
        "additionalProperties": false
      },
      "OkWithSlug": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "slug": {
            "type": "string"
          }
        },
        "required": [
          "ok",
          "slug"
        ],
        "additionalProperties": false
      },
      "Credential": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Credential name",
            "example": "linear"
          },
          "host": {
            "type": "string",
            "description": "Target hostname",
            "example": "api.linear.app"
          },
          "path": {
            "type": "string",
            "description": "Full credential path",
            "example": "/org_ruzo/linear"
          },
          "authKind": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Credential auth kind",
            "example": "headers"
          },
          "createdAt": {
            "type": "string",
            "description": "ISO 8601 creation timestamp"
          }
        },
        "required": [
          "name",
          "host",
          "path",
          "authKind",
          "createdAt"
        ],
        "additionalProperties": false
      },
      "CredentialError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "additionalProperties": false
      },
      "CredentialListPage": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Credential"
            }
          },
          "hasMore": {
            "type": "boolean",
            "description": "Whether more items remain after this page"
          },
          "nextCursor": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Cursor to request the next page"
          }
        },
        "required": [
          "data",
          "hasMore",
          "nextCursor"
        ],
        "additionalProperties": false
      },
      "CreateCredentialRequest": {
        "type": "object",
        "properties": {
          "token": {
            "description": "API token or secret",
            "type": "string"
          },
          "headers": {
            "description": "Explicit header map to send on proxied requests",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "host": {
            "description": "Target hostname for this credential",
            "example": "api.linear.app",
            "type": "string"
          },
          "profile": {
            "description": "Credential profile slug to derive the target host from",
            "example": "linear",
            "type": "string"
          },
          "path": {
            "description": "Full credential path (defaults to token path + name)",
            "example": "/org_ruzo/linear",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "DeleteCredentialQuery": {
        "type": "object",
        "properties": {
          "path": {
            "description": "Full credential path to delete",
            "example": "/org_ruzo/linear",
            "type": "string"
          },
          "host": {
            "description": "Target hostname for the credential",
            "example": "api.linear.app",
            "type": "string"
          },
          "profile": {
            "description": "Profile slug to resolve the hostname when host is omitted",
            "example": "linear",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TokenConstraint": {
        "type": "object",
        "properties": {
          "actions": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "hosts": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "roots": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "services": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "methods": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "DELETE",
                  "PATCH",
                  "HEAD",
                  "OPTIONS"
                ]
              },
              {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "GET",
                    "POST",
                    "PUT",
                    "DELETE",
                    "PATCH",
                    "HEAD",
                    "OPTIONS"
                  ]
                }
              }
            ]
          },
          "paths": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            ]
          },
          "ttl": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              }
            ]
          }
        },
        "additionalProperties": false
      },
      "CreateTokenRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "constraints": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenConstraint"
            }
          }
        },
        "additionalProperties": false
      },
      "TokenRight": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          },
          "root": {
            "type": "string"
          }
        },
        "required": [
          "action",
          "root"
        ],
        "additionalProperties": false
      },
      "CreateTokenResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "rights": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenRight"
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenConstraint"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "expiresAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "lastUsedAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "revokedAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "revokeReason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "ok": {
            "type": "boolean",
            "const": true
          },
          "token": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "rights",
          "constraints",
          "createdAt",
          "expiresAt",
          "lastUsedAt",
          "revokedAt",
          "revokeReason",
          "ok",
          "token"
        ],
        "additionalProperties": false
      },
      "InspectTokenRequest": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Token to inspect"
          }
        },
        "required": [
          "token"
        ],
        "additionalProperties": false
      },
      "InspectTokenResponse": {
        "type": "object",
        "properties": {
          "valid": {
            "type": "boolean",
            "const": true
          },
          "userId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "orgId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "rights": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenRight"
            }
          },
          "homePath": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "valid",
          "userId",
          "orgId",
          "rights",
          "homePath",
          "scopes"
        ],
        "additionalProperties": false
      },
      "IssuedToken": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "rights": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenRight"
            }
          },
          "constraints": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenConstraint"
            }
          },
          "createdAt": {
            "type": "string"
          },
          "expiresAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "lastUsedAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "revokedAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "revokeReason": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "id",
          "name",
          "rights",
          "constraints",
          "createdAt",
          "expiresAt",
          "lastUsedAt",
          "revokedAt",
          "revokeReason"
        ],
        "additionalProperties": false
      },
      "IssuedTokenListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IssuedToken"
            }
          }
        },
        "required": [
          "data"
        ],
        "additionalProperties": false
      },
      "RevokeTokenRequest": {
        "type": "object",
        "properties": {
          "reason": {
            "description": "Reason for revoking the token",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RevokeTokenResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "const": true
          },
          "id": {
            "type": "string"
          },
          "revokedAt": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "revokedIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of revoked token block IDs"
          }
        },
        "required": [
          "ok",
          "id",
          "revokedAt",
          "revokedIds"
        ],
        "additionalProperties": false
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "health",
      "description": "Health check"
    },
    {
      "name": "cred_profiles",
      "description": "Credential profile management"
    },
    {
      "name": "credentials",
      "description": "Credential storage and retrieval"
    },
    {
      "name": "tokens",
      "description": "Token management"
    },
    {
      "name": "proxy",
      "description": "Authenticated proxy"
    },
    {
      "name": "auth",
      "description": "Authentication endpoints"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "operationId": "getIndex",
        "tags": [
          "health"
        ],
        "summary": "Health check",
        "description": "Returns a list of configured credential profiles with credential counts.",
        "responses": {
          "200": {
            "description": "Health status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "profiles": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "slug": {
                            "type": "string"
                          },
                          "credentialCount": {
                            "type": "number"
                          }
                        },
                        "required": [
                          "slug",
                          "credentialCount"
                        ]
                      }
                    }
                  },
                  "required": [
                    "profiles"
                  ],
                  "id": "HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/credentials": {
      "get": {
        "operationId": "getCredentials",
        "tags": [
          "credentials"
        ],
        "summary": "List credentials",
        "description": "List credentials accessible to this token with cursor-based pagination. Optionally filter by path prefix.",
        "responses": {
          "200": {
            "description": "Paginated list of credentials",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialListPage"
                }
              }
            }
          },
          "400": {
            "description": "Invalid pagination cursor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CredentialError"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 100,
              "example": 100,
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "description": "Maximum number of items to return (1-100)"
          },
          {
            "in": "query",
            "name": "cursor",
            "schema": {
              "example": "eyJzbHVnIjoiL2dpdGh1YiJ9",
              "type": "string"
            },
            "description": "Opaque cursor returned by a previous list response"
          },
          {
            "in": "query",
            "name": "path",
            "schema": {
              "example": "/org_ruzo",
              "type": "string"
            },
            "description": "Filter to credentials under this path prefix"
          }
        ]
      }
    },
    "/credentials/{name}": {
      "put": {
        "operationId": "putCredentialsByName",
        "tags": [
          "credentials"
        ],
        "summary": "Store credential",
        "description": "Create or update a credential for a service. Provide either a token or explicit headers.",
        "responses": {
          "200": {
            "description": "Credential stored",
            "content": {
              "application/json": {
