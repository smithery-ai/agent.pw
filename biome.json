{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "plugins": [
    "node_modules/biome-plugin-no-type-assertion/no-type-assertion.grit"
  ],
  "files": {
    "includes": [
      "**",
      "!coverage",
      "!**/dist",
      "!.context",
      "!**/.context",
      "!.claude",
      "!**/.claude",
      "!node_modules",
      "!**/node_modules",
      "!.workers-biscuit-pr",
      "!**/.git"
    ]
  }
}
